// NOTE: This is managed by the SDK and is readonly
{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [".opencode/rules/*"],
	"mcp": {
		// Lattice MCP helps reduce token consumption.
		// SEE: https://yogthos.net/posts/2026-01-16-lattice-mcp.html
		// Use the installed binary instead of `bun x` to avoid cache and ABI drift.
		// You can validate this with: opencode mcp list | grep lattice
		"lattice": {
			"type": "local",
			"command": ["lattice-mcp"],
			"enabled": true
		},
		"playwright": {
			"type": "local",
			"command": [
				"xvfb-run",
				"-a",
				"env",
				"HEADLESS=true",
				"PLAYWRIGHT_HEADLESS=true",
				"PW_HEADLESS=1",
				"bun",
				"x",
				"-y",
				"@playwright/mcp@latest"
			],
			"enabled": true
		},
		//"context7": {
		//	"type": "remote",
		//	"url": "https://mcp.context7.com/mcp",
		//	"headers": {
		//		"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
		//	},
		//	"enabled": true
		//},
		"context7": {
			"type": "local",
			"command": [
				"bun",
				"x",
				"-y",
				"@upstash/context7-mcp",
				"--api-key",
				"{env:CONTEXT7_API_KEY}"
			],
			"enabled": true
		}
	}
}
// EOF
